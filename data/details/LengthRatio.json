{
  "description_cn": "<p>在一对线的长度之间保持固定比例。</p><p>使两组直线的长度比例始终保持为设定的固定比例。</p>",
  "description_en": "<p><span style=\"color: rgb(0, 0, 0);\">Maintain a fixed ratio between the lengths of a pair of lines</span></p><p>The length ratio of the two sets of straight lines is always kept at a fixed ratio.</p>",
  "images": [
    "LengthRatio.png",
    "LengthRatio.gif"
  ],
  "video": "",
  "tags": [
    "线"
  ],
  "parameters": [
    {
      "name": "LineA",
      "cn": "直线A",
      "en": "LineA",
      "default": "Null，直线",
      "desc_cn": "第一条直线",
      "desc_en": "First line segment"
    },
    {
      "name": "LineB",
      "cn": "直线B",
      "en": "LineB",
      "default": "Null，直线",
      "desc_cn": "第二条直线",
      "desc_en": "Second line segment"
    },
    {
      "name": "Ratio",
      "cn": "比率",
      "en": "Ratio",
      "default": "2，数字",
      "desc_cn": "长度B除以长度A",
      "desc_en": "Length B divided by Length A"
    },
    {
      "name": "Strength",
      "cn": "强度",
      "en": "Strength",
      "default": "1，数字",
      "desc_cn": "强度",
      "desc_en": "Strength"
    }
  ],
  "outputs": [
    {
      "name": "A",
      "cn": "角度",
      "en": "Angle",
      "default": "Null",
      "desc_cn": "生成的角度",
      "desc_en": "Angle out"
    }
  ],
  "examples": [
    "LengthRatio_example.gh"
  ],
