      "name": "LineA",
      "cn": "直线",
      "en": "LineA",
      "default": "Null，直线",
      "desc_cn": "第一组直线",
      "desc_en": "First line segment"
    },
    {
      "name": "LineB",
      "cn": "直线",
      "en": "LineB",
      "default": "Null，直线",
      "desc_cn": "第二组直线",
      "desc_en": "Second line segment"
    },
    {
      "name": "Strength",
      "cn": "权重，强度",
      "en": "Strength",
      "default": "1",
      "desc_cn": "权重，强度",
      "desc_en": "Strength"
    },
    {
      "name": "Factor",
      "cn": "系数",
