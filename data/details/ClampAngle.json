{
  "description_cn": "限制角度范围，将角度约束在最小值和最大值之间。和Angle一样，只不过这里可以设置上下限，对超过限度的角度不会施加任何力。",
  "description_en": "Limit the angle range, constraining the angle between its minimum and maximum values. Similar to Angle, except that upper and lower limits can be set here, and no force will be applied to angles exceeding the limits.",
  "images": [
    "ClampAngle.png",
    "ClampAngle.gif"
  ],
  "video": "",
  "tags": [
    "约束",
    "线",
    "角度"
  ],
  "parameters": [
    {
      "name": "LineA",
      "cn": "直线A",
      "en": "LineA",
      "default": "Null，直线",
      "desc_cn": "第一组直线列表",
      "desc_en": "First line segment"
    },
    {
      "name": "LineB",
      "cn": "直线B",
      "en": "LineB",
      "default": "Null，直线",
      "desc_cn": "第二组直线列表",
      "desc_en": "Second line segment"
    },
    {
      "name": "Upper",
      "cn": "上限",
      "en": "UpperLimit",
      "default": "0.5*pi，弧度",
      "desc_cn": "允许的最大角度（弧度）",
      "desc_en": "Maximum allowed angle in radians"
    },
    {
      "name": "Lower",
      "cn": "下限",
      "en": "LowerLimit",
      "default": "0.785398",
      "desc_cn": "允许的最小角度（弧度）",
      "desc_en": "Minimum allowed angle in radians"
    },
    {
      "name": "Strength",
      "cn": "权重，强度",
      "en": "Strength",
      "default": "1",
      "desc_cn": "权重，强度",
      "desc_en": "Strength"
    }
  ],
  "outputs": [
    {
      "name": "C",
      "cn": "角度",
      "en": "ClampAngle",
      "default": "Null",
      "desc_cn": "生成的夹角",
      "desc_en": "ClampAngle out"
    }
  ],
  "examples": [
    "ClampAngle_examples.gh"
  ],
  "author": "Kangaroo Team",
  "version": "2.1",
  "lastUpdated": "2026-04-15"
}
